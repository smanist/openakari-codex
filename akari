#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CLI_JS="$ROOT_DIR/infra/scheduler/dist/cli.js"

if [[ ! -f "$CLI_JS" ]]; then
  echo "Scheduler CLI is not built. Run: cd infra/scheduler && npm install && npm run build" >&2
  exit 1
fi

exec node "$CLI_JS" "$@"
